        ],
        flashcards: [
          { id: "mp-c1", question: "How is the change in velocity calculated from an acceleration-time graph?", answer: "By calculating the definite integral (or area under the curve) of the acceleration-time graph over the given time interval." }
        ]
      }
    ]
